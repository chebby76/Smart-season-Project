# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Database Configuration
# For SQLite (development):
DB_DIALECT=sqlite
DB_STORAGE=./database.sqlite

# For PostgreSQL (production):
# DB_DIALECT=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=smartseason
# DB_USER=postgres
# DB_PASSWORD=your_password
